{
  "model": "shop.artist",
  "pk": 1,
  "fields": {
    "name": "Neeraj Gupta",
    "genre": "male",
    "dob": "1967",
    "image": "https://res.cloudinary.com/dkemgt2zs/image/upload/q_auto/f_auto/v1777808578/Neeraj_Gupta_rdjqig.jpg",
    "about": "A sculptor working in stone, bronze, and terracotta, Gupta revives ancient Indian clay traditions with contemporary forms. His terracotta works explore human emotions, nature, and the rural-urban divide.",
    "is_top": true,
    "short_about": "Terracotta artist"
  }
},
{
  "model": "shop.artist",
  "pk": 2,
  "fields": {
    "name": "S. Nandagopal",
    "genre": "male",
    "dob": "1946",
    "image": "https://res.cloudinary.com/dkemgt2zs/image/upload/v1777806851/images_fmmwwl.jpg",
    "about": "Son of painter K.C.S. Paniker, he created intricate bronze sculptures drawing from South Indian temple art. His modernist works feature mythical figures and animals, earning him the Padma Shri in 2007.",
    "is_top": true,
    "short_about": "Metal artist"
  }
},
{
  "model": "shop.artist",
  "pk": 3,
  "fields": {
    "name": "Sita Devi",
    "genre": "Female",
    "dob": "1914",
    "image": "https://res.cloudinary.com/dkemgt2zs/image/upload/v1777806159/sita_devi-1100-X-600-850x560_pefoq8.webp",
    "about": "She was the first Madhubani artist to receive Padma Shri (1981) and pioneered the Bharni style with vibrant colors and Hindu deities. Her work transformed this traditional folk art into a globally recognized contemporary form",
    "is_top": true,
    "short_about": "Madhubani artist"
  }
},
{
  "model": "shop.artist",
  "pk": 4,
  "fields": {
    "name": "Manisha Gera Baswani",
    "genre": "Female",
    "dob": "1967",
    "image": "https://res.cloudinary.com/dkemgt2zs/image/upload/v1777808901/Paletteofpain1_j8lvlg.avif",
    "about": "A multidisciplinary artist working in glass art, painting, and photography. Her notable project \"Postcards from Home\" documents India's Partition through studio portraits of 47 artists. The exhibition was featured at the Ashmolean Museum and Lahore Biennale.",
    "is_top": true,
    "short_about": "Painting, and Photography"
  }
},
{
  "model": "shop.artist",
  "pk": 5,
  "fields": {
    "name": "Jyotsna Bhatt",
    "genre": "Female",
    "dob": "1940",
    "image": "https://res.cloudinary.com/dkemgt2zs/image/upload/v1777809175/Jyotsna_Bhatt_died_2020_ceramicist_u1wiz9.png",
    "about": "One of India's finest ceramic artists, she is known for hand-built terracotta rejecting the potter's wheel. Her minimalist, organic forms (spheres, cats, animal shapes) and glazed pottery are distinctive. She taught at M.S. University Baroda and helped establish ceramics as a specialization there.",
    "is_top": true,
    "short_about": "Hand-built terracotta"
  }
},
{
  "model": "shop.artist",
  "pk": 6,
  "fields": {
    "name": "Rana Pandey",
    "genre": "male",
    "dob": "Not publicly disclosed (active 2010sûpresent)",
    "image": "https://res.cloudinary.com/dkemgt2zs/image/upload/v1777809510/images_1_aajey3.jpg",
    "about": "Kolkata-based documentary and travel photographer. He has won international accolades including Istanbul Photo Awards (2024) and Andrei Stenin International Press Photo Contest (2017, 2022, 2024). His ongoing project \"Torn Between the Tiger and the Tide\" documents human-animal conflict and climate change in the Sundarbans. His approach focuses on patience, observation, and telling stories of marginalized communities with dignity.",
    "is_top": true,
    "short_about": "Photographer"
  }
},
